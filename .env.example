SMTP_PORT=587
MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/crowdfaq?retryWrites=true&w=majority
DNS_SERVERS=8.8.8.8
API_PORT=3000
FRONTEND_ORIGIN=http://localhost:5174,http://127.0.0.1:5174
VITE_API_URL=http://localhost:3000
JWT_SECRET=replace_with_a_random_secret_at_least_32_characters_long
JWT_EXPIRES_IN=7d
OPENAI_API_KEY=
